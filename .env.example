# Application settings
PROJECT_NAME=HR Management Backend
PROJECT_VERSION=0.1.0
PROJECT_DESCRIPTION=Modular FastAPI backend skeleton for an HR management system
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-secret-in-production
API_V1_PREFIX=/api/v1
APP_HOST=0.0.0.0
APP_PORT=8000
# Trust forwarded headers only from known reverse proxies.
# Railway deployments using the Dockerfile already set this to * inside the container.
FORWARDED_ALLOW_IPS=127.0.0.1
# Comma-separated web frontend origins allowed to call the API through CORS.
# This affects browser-based clients only.
# Development web origin example: http://localhost:3000
# Production web origin example: https://my-web-frontend.app
# Android and Windows desktop clients can still use the API with normal authentication.
CORS_ALLOW_ORIGINS=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database settings
# Use SQLite for local development.
DATABASE_URL=sqlite:///./hr_management.db
# Leave DATABASE_URL empty to assemble a PostgreSQL DSN from the variables below.
# DATABASE_URL=
POSTGRES_DB=hr_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy settings
DB_ECHO=false

# Initial system bootstrap values
SUPERADMIN_MATRICULE=SA-0001
SUPERADMIN_PASSWORD=change-this-bootstrap-password
SUPERADMIN_FIRST_NAME=System
SUPERADMIN_LAST_NAME=Administrator
SUPERADMIN_EMAIL=superadmin@example.com
